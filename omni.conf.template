# Omni env config. Live values live in `omni.conf` (gitignored, on the server
# at /home/ubuntu/huly-selfhost/omni.conf).
#
# Layout: vars you MUST change are at the top. Structural vars (internal
# addressing, connector list) come next. Tunables with sensible defaults
# defined in compose.omni.yml are listed commented-out at the bottom —
# uncomment to override.
#
# First-time setup on the server:
#   cp omni.conf.template omni.conf
#   $EDITOR omni.conf            # fill in CHANGE_ME values + APP_URL hostname
#
# Bumping the Omni version:
#   $EDITOR omni.conf            # set OMNI_VERSION=v0.x.y (or `latest`)
#   ./release.sh                 # from your laptop

# =============================================================================
# Required: must change before first deploy
# =============================================================================

# Container image source. Combine registry + namespace; compose appends the
# service name + version (e.g. ${OMNI_IMAGE_PREFIX}/omni-web:${OMNI_VERSION}).
# Examples:
#   GHCR private fork:    ghcr.io/<org>/<repo>
#   Docker Hub:           docker.io/<org>
#   Self-hosted registry: registry.example.com/<namespace>
# For private GHCR namespaces, run `docker login ghcr.io` on the server once.
OMNI_IMAGE_PREFIX=CHANGE_ME_image_registry_and_namespace

# Image tag. `latest` only exists when a `v*` git tag is pushed and CI
# completes successfully — otherwise pin to a real tag (e.g. v0.2.0).
OMNI_VERSION=latest

# Per-service tag override — e.g. when only the web image was rebuilt by a
# branch push (path-filtered CI), pin OMNI_WEB_VERSION=master-<sha> while
# leaving OMNI_VERSION at the last full release. Unset → falls through to
# OMNI_VERSION. Same idea can be added for other services if needed.
#OMNI_WEB_VERSION=

# Database password. Generate with: openssl rand -hex 16
DATABASE_PASSWORD=CHANGE_ME_long_random_string

# Public app URL. Used for SvelteKit cookie domain, redirect URLs, and CSRF
# (ORIGIN). Replace example.com with your real hostname.
APP_URL=https://omni.example.com

# Encryption keys for connector credentials in the DB. Read by web, indexer,
# ai, and connector-manager — they must agree.
# Generate with:
#   ENCRYPTION_KEY:  openssl rand -hex 32
#   ENCRYPTION_SALT: openssl rand -hex 8
ENCRYPTION_KEY=CHANGE_ME_at_least_32_chars_random
ENCRYPTION_SALT=CHANGE_ME_16chars

# =============================================================================
# Structural: change only if you know why
# =============================================================================

# Database (internal — postgres service on omni_net)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=omni
DATABASE_NAME=omni

# Redis (internal)
REDIS_URL=redis://redis:6379

# Cross-service URLs. Internal listening ports are hardcoded in
# compose.omni.yml; these defaults match. Override only to point a service
# at an external host (e.g. a self-hosted AI service).
SEARCHER_URL=http://searcher:3001
INDEXER_URL=http://indexer:3002
AI_SERVICE_URL=http://ai:3003
CONNECTOR_MANAGER_URL=http://connector-manager:3004

# Connectors enabled via compose profiles (comma-separated).
# Available: google,slack,atlassian,web,github,notion,hubspot,fireflies,
#            microsoft,filesystem,imap,linear,clickup,nextcloud,paperless
# Each requires the matching service block (with `profiles: [<name>]`) in
# compose.omni.yml.
ENABLED_CONNECTORS=web

# Optional: add `embeddings` to also start the local Ollama embeddings
# service (google/embeddinggemma-300m by default). After enabling, configure
# the provider in the admin UI at /admin/settings/embeddings:
#   - Type:  Local
#   - URL:   http://embeddings:11434/v1
#   - Model: embeddinggemma:300m
#   - Click "Set as Current" to trigger reindex.
COMPOSE_PROFILES=${ENABLED_CONNECTORS}

# Local embeddings (Ollama). Only used when COMPOSE_PROFILES includes
# `embeddings`. EMBEDDING_MODEL is an Ollama model name (see
# https://ollama.com/library). embeddinggemma:300m outputs 768-dim dense
# vectors and matches the pre-baked partial HNSW index. Other multilingual
# choices: bge-m3 (1024-dim, slower but stronger) or mxbai-embed-large
# (English-only).
#EMBEDDING_MODEL=embeddinggemma:300m
#LOCAL_EMBEDDINGS_PORT=11434

# =============================================================================
# Tunable: defaults defined in compose.omni.yml. Uncomment to override.
# =============================================================================

# --- Database pool ---
#DB_MAX_CONNECTIONS=10
#DB_ACQUIRE_TIMEOUT_SECONDS=3

# --- Session ---
#SESSION_COOKIE_NAME=auth-session
#SESSION_DURATION_DAYS=7

# --- AI service ---
#AI_WORKERS=2

# --- Connector manager scheduling ---
#MAX_CONCURRENT_SYNCS=10
#MAX_CONCURRENT_SYNCS_PER_TYPE=3
#SCHEDULER_INTERVAL_SECONDS=60
# Per-source recrawl/sync intervals are NOT env vars — configure them per
# source in the admin UI; values are stored in the DB.

# --- Storage backend (postgres = blobs in DB; s3 = use an S3 bucket) ---
#STORAGE_BACKEND=postgres

# --- Logging ---
#RUST_LOG=info
