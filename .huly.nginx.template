# --- Logto subdomains (optional; active when `logto` profile is running) ---

server {
    listen 443 ssl;
    server_name auth.example.com;
    client_max_body_size 4M;

    ssl_certificate /etc/letsencrypt/live/huly/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/huly/privkey.pem;

    # Logto user-facing: /oidc/*, sign-in experience, /.well-known, non-admin /api.
    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        set $up http://logto:3001;
        proxy_pass $up;
    }
}

server {
    listen 443 ssl;
    server_name admin-auth.example.com;
    client_max_body_size 4M;

    ssl_certificate /etc/letsencrypt/live/huly/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/huly/privkey.pem;

    # Logto admin console. Separate subdomain so the admin SPA's absolute
    # `/assets/*` paths resolve against logto:3002 (admin port), not logto:3001.
    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        set $up http://logto:3002;
        proxy_pass $up;
    }
}
